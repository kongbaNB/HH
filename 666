local function startSmoothFollow(targetPlayer)
    if smoothFollowConnection then smoothFollowConnection:Disconnect() end
    smoothFollowTarget = targetPlayer
    local lastSmooth = 0
    smoothFollowConnection = RunService.Heartbeat:Connect(function(dt)
        if not smoothFollowTarget or not smoothFollowTarget:IsDescendantOf(Players) or not smoothFollowTarget.Character or not smoothFollowTarget.Character:FindFirstChild("HumanoidRootPart") then
            stopSmoothFollow()
            WindUI:Notify({ Title = "平滑跟随", Content = "目标已消失，跟随停止", Duration = 3 })
            return
        end
        local now = tick()
        if now - lastSmooth < 0.3 then return end
        lastSmooth = now
        local myChar = LocalPlayer.Character
        if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
        local myRoot = myChar.HumanoidRootPart
        local targetRoot = smoothFollowTarget.Character.HumanoidRootPart
        local targetPos = targetRoot.Position
        local myPos = myRoot.Position
        local dist = (targetPos - myPos).Magnitude
        if dist > 4 then
            local direction = (targetPos - myPos).Unit
            local speed = math.min(dist * 2, 50)
            local newPos = myPos + direction * speed * dt
            myRoot.CFrame = CFrame.new(newPos, targetPos)
        end
    end)
    WindUI:Notify({ Title = "平滑跟随", Content = "开始平滑跟随 " .. targetPlayer.Name, Duration = 3 })
end

