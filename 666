local function disablePlayerCollision(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    pcall(function()
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                if antiFlingOriginalStates[part] == nil then
                    antiFlingOriginalStates[part] = part.CanCollide
                end
                part.CanCollide = false
            end
        end
    end)
end

local function enablePlayerCollision(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    pcall(function()
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                if antiFlingOriginalStates[part] ~= nil then
                    part.CanCollide = antiFlingOriginalStates[part]
                    antiFlingOriginalStates[part] = nil
                end
            end
        end
    end)
end

local function enableAllPlayersCollision()
    for part, state in pairs(antiFlingOriginalStates) do
        pcall(function()
            if part and part.Parent then
                part.CanCollide = state
            end
        end)
    end
    antiFlingOriginalStates = {}
end

local function setupAntiFlingForPlayer(player)
    if player == LocalPlayer then return end
    disablePlayerCollision(player)
    if antiFlingCharAddedConns[player] then
        pcall(function() antiFlingCharAddedConns[player]:Disconnect() end)
    end
    antiFlingCharAddedConns[player] = player.CharacterAdded:Connect(function(char)
        if not AntiFlingEnabled then return end
        task.spawn(function()
            task.wait(0.3)
            if AntiFlingEnabled and player.Parent then
                disablePlayerCollision(player)
            end
        end)
    end)
end

local function cleanupAntiFlingForPlayer(player)
    if antiFlingCharAddedConns[player] then
        pcall(function() antiFlingCharAddedConns[player]:Disconnect() end)
        antiFlingCharAddedConns[player] = nil
    end
    enablePlayerCollision(player)
end

local function startAntiFling()
    if AntiFlingConnection then AntiFlingConnection:Disconnect() end
    for _, p in ipairs(Players:GetPlayers()) do
        setupAntiFlingForPlayer(p)
    end
    local lastAntiFlingCheck = 0
    AntiFlingConnection = RunService.Heartbeat:Connect(function()
        local now = tick()
        if now - lastAntiFlingCheck >= 2.0 then
            lastAntiFlingCheck = now
            local allPlayers = Players:GetPlayers()
            for _, p in ipairs(allPlayers) do
                if p ~= LocalPlayer and p.Character then
                    pcall(function()
                        local char = p.Character
                        for _, part in ipairs(char:GetDescendants()) do
                            if part:IsA("BasePart") and part.CanCollide then
                                if antiFlingOriginalStates[part] == nil then
                                    antiFlingOriginalStates[part] = part.CanCollide
                                end
                                part.CanCollide = false
                            end
                        end
                    end)
                end
            end
        end
        local char = LocalPlayer.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                if root.Velocity.Magnitude > 500 then
                    root.Velocity = Vector3.new(0, 0, 0)
                    root.RotVelocity = Vector3.new(0, 0, 0)
                end
                root.CanCollide = true
            end
        end
    end)
end

local function stopAntiFling()
    if AntiFlingConnection then AntiFlingConnection:Disconnect() end
    AntiFlingConnection = nil
    for player, conn in pairs(antiFlingCharAddedConns) do
        pcall(function() conn:Disconnect() end)
    end
    antiFlingCharAddedConns = {}
    enableAllPlayersCollision()
end

