local finished = false
local function leave(loadSource)
    if finished then return end
    finished = true
    local exitTween
    if loadSource then
        exitTween = TweenService:Create(frame, TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.In), { Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(1, -127.5, 0, 71.25) })
    else
        exitTween = TweenService:Create(frame, TweenInfo.new(0.6, Enum.EasingStyle.Quart, Enum.EasingDirection.In), { Position = UDim2.new(1, 240, 0, 15) })
    end
    exitTween:Play()
    exitTween.Completed:Wait()
    popupGui:Destroy()
    if loadSource then
        local ok, err = pcall(function()
            loadstring(game:HttpGet(SourceUrl))()
        end)
        if not ok then
            warn(err)
        end
    end
end

yesBtn.MouseButton1Click:Connect(function()
    task.spawn(leave, true)
end)
noBtn.MouseButton1Click:Connect(function()
    task.spawn(leave, false)
end)
closeBtn.MouseButton1Click:Connect(function()
    task.spawn(leave, false)
end)

task.spawn(function()
    local remaining = 7
    while not finished and remaining > 0 do
        local cs = math.max(0, math.floor(remaining * 100 + 0.5))
        timeLabel.Text = string.format("%d:%02d", math.floor(cs / 100), cs % 100)
        task.wait(0.01)
        remaining = remaining - 0.01
    end
    if not finished then
        leave(false)
    end
end)

return true
