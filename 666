Tabs.MiscTab:Button({
    Title = "确认播放",
    Callback = function()
        local id = tostring(musicId):gsub("%D", "")
        if id == "" then
            WindUI:Notify({ Title = "音乐", Content = "请先输入音乐ID", Duration = 3 })
            return
        end
        if musicSound and musicSound.SoundId == "rbxassetid://" .. id and musicSound.IsPaused then
            musicSound:Resume()
            WindUI:Notify({ Title = "音乐", Content = "继续播放: " .. id, Duration = 3 })
            return
        end
        if musicSound then
            musicSound:Destroy()
            musicSound = nil
        end
        musicSound = Instance.new("Sound")
        musicSound.SoundId = "rbxassetid://" .. id
        musicSound.Volume = 1
        musicSound.Looped = true
        musicSound.Parent = LocalPlayer:WaitForChild("PlayerGui")
        musicSound:Play()
        WindUI:Notify({ Title = "音乐", Content = "正在播放: " .. id, Duration = 3 })
    end
})

