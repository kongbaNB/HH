local serversFile = "servers_" .. plrId .. ".json"
local savedServers = {}

local function loadSavedServers()
    local success, data = pcall(function() return readfile(serversFile) end)
    if success and data and data ~= "" then
        local decoded = HttpService:JSONDecode(data)
        if decoded and type(decoded) == "table" then
            savedServers = {}
            for _, item in ipairs(decoded) do
                if type(item) == "string" then table.insert(savedServers, {id = item, name = item})
                elseif type(item) == "table" and item.id then table.insert(savedServers, {id = tostring(item.id), name = item.name or tostring(item.id)})
                end
            end
        end
    end
    local seen = {}
    local unique = {}
    for _, entry in ipairs(savedServers) do
        if not seen[entry.id] then seen[entry.id] = true table.insert(unique, entry) end
    end
    savedServers = unique
end

local function saveServers()
    task.spawn(function()
        pcall(function()
            writefile(serversFile, HttpService:JSONEncode(savedServers))
        end)
    end)
end

local function addServerId(id, name)
    if not id or id == "" then return end
    local sid = tostring(id)
    for _, entry in ipairs(savedServers) do
        if entry.id == sid then
            if name and name ~= entry.name then entry.name = name saveServers() end
            return
        end
    end
    table.insert(savedServers, {id = sid, name = name or sid})
    saveServers()
end

local function removeServerId(id)
    if not id then return end
    local sid = tostring(id)
    local newList = {}
    for _, entry in ipairs(savedServers) do
        if entry.id ~= sid then table.insert(newList, entry) end
    end
    savedServers = newList
    task.spawn(function()
        pcall(function()
            writefile(serversFile, HttpService:JSONEncode(savedServers))
        end)
    end)
    return true
end

local function renameServerId(id, newName)
    if not newName or newName == "" then return false end
    local sid = tostring(id)
    for _, entry in ipairs(savedServers) do
        if entry.id == sid then
            entry.name = newName
            saveServers()
            return true
        end
    end
    return false
end

