local activeImpersonateClone = nil
local selectedImpersonateName = ""

local function resetImpersonate()
    if activeImpersonateClone then
        activeImpersonateClone:Destroy()
        activeImpersonateClone = nil
    end
    local realChar = LocalPlayer.Character
    if realChar then
        for _, v in ipairs(realChar:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("Decal") then
                v.Transparency = 0
            end
        end
    end
end

local function startImpersonate(targetName)
    local target = Players:FindFirstChild(targetName)
    if not target or not target.Character then
        WindUI:Notify({Title = "错误", Content = "目标玩家不存在或角色未加载", Type = "error"})
        return
    end

    resetImpersonate()
    task.wait(0.2)

    local targetChar = target.Character
    local realChar = LocalPlayer.Character
    if not realChar then
        WindUI:Notify({Title = "错误", Content = "你的角色未加载", Type = "error"})
        return
    end

    targetChar.Archivable = true
    local clone = targetChar:Clone()
    clone.Name = "ImpersonateClone"
    clone.Parent = workspace
    activeImpersonateClone = clone

    local cloneHum = clone:FindFirstChildOfClass("Humanoid")
    if cloneHum then
        cloneHum.DisplayName = targetName
    end

    if realChar then
        for _, v in ipairs(realChar:GetDescendants()) do
            if v:IsA("BasePart") or v:IsA("Decal") then
                v.Transparency = 1
            end
        end
    end

    local realHum = realChar:FindFirstChildOfClass("Humanoid")
    if realHum then
        realHum.Died:Connect(function()
            resetImpersonate()
        end)
    end

    task.spawn(function()
        while activeImpersonateClone and activeImpersonateClone.Parent do
            local myChar = LocalPlayer.Character
            if myChar then
                local myRoot = myChar:FindFirstChild("HumanoidRootPart")
                local cloneRoot = activeImpersonateClone:FindFirstChild("HumanoidRootPart")
                if myRoot and cloneRoot then
                    cloneRoot.CFrame = myRoot.CFrame
                end
                local myHum = myChar:FindFirstChildOfClass("Humanoid")
                local cloneHumanoid = activeImpersonateClone:FindFirstChildOfClass("Humanoid")
                if myHum and cloneHumanoid then
                    cloneHumanoid:Move(myHum.MoveDirection)
                end
            end
            task.wait()
        end
    end)

    WindUI:Notify({Title = "成功", Content = "已伪装成: " .. targetName .. "（仅自己可见）", Type = "success"})
end


