local followTarget = nil
local followConnection = nil
local followRange = 5
local function startFollow(targetPlayer)
    if followConnection then followConnection:Disconnect() end
    followTarget = targetPlayer
    local lastFollow = 0
    followConnection = RunService.Heartbeat:Connect(function()
        if not followTarget or not followTarget:IsDescendantOf(Players) or not followTarget.Character or not followTarget.Character:FindFirstChild("HumanoidRootPart") then
            followConnection:Disconnect()
            followConnection = nil
            followTarget = nil
            WindUI:Notify({ Title = "跟随", Content = "目标已消失，跟随停止", Duration = 3 })
            return
        end
        local now = tick()
        if now - lastFollow < 0.5 then return end
        lastFollow = now
        local myChar = LocalPlayer.Character
        if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
        local myRoot = myChar.HumanoidRootPart
        local myHum = myChar:FindFirstChildOfClass("Humanoid")
        if not myHum then return end
        local targetRoot = followTarget.Character.HumanoidRootPart
        local dist = (targetRoot.Position - myRoot.Position).Magnitude
        if dist > followRange then
            myHum:MoveTo(targetRoot.Position)
        else
            myHum:MoveTo(myRoot.Position)
        end
    end)
    WindUI:Notify({ Title = "跟随", Content = "开始跟随 " .. targetPlayer.Name, Duration = 3 })
end

local function stopFollow()
    if followConnection then followConnection:Disconnect() end
    followConnection = nil
    followTarget = nil
    local myChar = LocalPlayer.Character
    if myChar then
        local myHum = myChar:FindFirstChildOfClass("Humanoid")
        if myHum then
            myHum:MoveTo(myChar:FindFirstChild("HumanoidRootPart") and myChar.HumanoidRootPart.Position or myChar:GetPivot().Position)
        end
    end
    WindUI:Notify({ Title = "跟随", Content = "已停止跟随", Duration = 3 })
end


