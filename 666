local matchedName = nil
for _, server in ipairs(ServerList) do
    for _, id in ipairs(server.Ids) do
        if game.PlaceId == id then
            matchedName = server.Name
            break
        end
    end
    if matchedName then break end
end

if not matchedName then
    return false
end

game:GetService("StarterGui"):SetCore("SendNotification", {
    Title = "已识别到在[" .. matchedName .. "]",
    Text = "已开始加载"
})

task.spawn(function()
    local startTime = tick()
    local ok, err = pcall(function()
        loadstring(ServerScripts[matchedName])()
    end)
    local elapsed = tick() - startTime
    if ok then
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "加载完毕！",
            Text = string.format("此次加载耗时:%.3f", elapsed)
        })
    else
        warn(err)
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "加载失败",
            Text = tostring(err)
        })
    end
end)

